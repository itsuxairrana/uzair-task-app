# Uzair Task OS — Environment Variables
# Copy this file to .env and fill in your keys
# The app works WITHOUT any keys using the Free Local Parser

# ── AI Models ─────────────────────────────────────────────
# Gemini — FREE at https://aistudio.google.com/app/apikey (recommended free option)
VITE_GEMINI_API_KEY=

# Claude — https://console.anthropic.com/ ($5 min deposit)
VITE_CLAUDE_API_KEY=

# OpenAI GPT-4o — https://platform.openai.com/
VITE_OPENAI_API_KEY=

# Grok — https://console.x.ai/
VITE_GROK_API_KEY=

# ── Google Workspace Sync (optional) ──────────────────────
# Setup: console.cloud.google.com → OAuth 2.0 Client ID
# Enable: Google Calendar API + Google Tasks API
# Add to Authorized JS Origins: http://localhost:5173
VITE_GOOGLE_CLIENT_ID=
